" ============================================================================
" vim-go 插件配置
" 文件位置: ~/.vim/after/plugin/vim_go.vim
" 说明: 此文件会在所有插件加载后自动执行，用于配置 vim-go 插件
" 策略: 禁用 LSP 功能，让 coc.nvim 接管，保留工具命令和语法高亮
" ============================================================================

" ============================================================================
" 1. 禁用 vim-go 的 LSP 功能 (让位给 coc.nvim)
" ============================================================================

" 禁止 vim-go 启动 gopls (否则会运行两个 gopls 实例，导致内存占用高和卡顿)
let g:go_gopls_enabled = 0

" 禁止 vim-go 的自动补全
let g:go_code_completion_enabled = 0

" 禁用自动类型信息和相同标识符高亮（这些功能由 coc.nvim 提供）
let g:go_auto_type_info = 0
let g:go_auto_sameids = 0

" ============================================================================
" 2. 禁用键位映射 (防止与 coc.nvim 冲突)
" ============================================================================

" 禁用 gd (跳转定义) 和 ctrl-]，交由 coc 的 nmap <silent> gd <Plug>(coc-definition) 处理
let g:go_def_mapping_enabled = 0

" 禁用 K (查看文档)，交由 coc 的 K 处理
let g:go_doc_keywordprg_enabled = 0

" ============================================================================
" 3. 格式化控制 (交给 coc.nvim 处理)
" ============================================================================

" 关闭 vim-go 的自动格式化，统一由 coc.nvim 处理
" 这样可以利用 coc 的 Organize Imports 功能
let g:go_fmt_autosave = 0
let g:go_imports_autosave = 0

" ============================================================================
" 4. 保留 vim-go 的精华 (高亮与工具)
" ============================================================================

" 开启更丰富的语法高亮 (这是 vim-go 强于 coc 的地方)
let g:go_highlight_types = 1
let g:go_highlight_fields = 1
let g:go_highlight_functions = 1
let g:go_highlight_function_calls = 1
let g:go_highlight_operators = 1
let g:go_highlight_extra_types = 1

" ============================================================================
" 5. 消息输出控制
" ============================================================================

" 禁用 vim-go 的命令信息输出（减少消息提示）
let g:go_echo_command_info = 0

" 禁用 Go 标识符信息输出
let g:go_echo_go_info = 0
