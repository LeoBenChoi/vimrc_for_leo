{
  // ============================================================================
  // coc.nvim 配置文件
  // 文件位置: ~/.vim/coc-settings.json (或 ~/.config/coc/coc-settings.json)
  // 说明: 此文件用于配置 coc.nvim 及其扩展的行为
  // 注意: JSON 文件支持注释（coc.nvim 扩展支持）
  // ============================================================================

  // ============================================================================
  // 基础配置
  // ============================================================================

  // 补全相关配置
  "suggest.noselect": true,
  "suggest.enablePreview": true,
  "suggest.enablePreselect": true,
  "suggest.disableKind": false,
  "suggest.timeout": 500,

  // 诊断相关配置
  "diagnostic.enable": true,
  "diagnostic.errorSign": "✗",
  "diagnostic.warningSign": "⚠",
  "diagnostic.infoSign": "ℹ",
  "diagnostic.hintSign": "➤",
  "diagnostic.virtualText": true,
  "diagnostic.messageTarget": "echo",

  // 代码片段相关配置
  "snippets.ultisnips.enable": false,
  "snippets.ultisnips.directories": [],

  // 语言服务器相关配置
  "languageserver": {},

  // ============================================================================
  // 扩展配置示例（根据需要取消注释并配置）
  // ============================================================================

  // Go 语言支持（需要安装 coc-go）
  // "go.gopath": "",
  // "go.goroot": "",
  // "go.useLanguageServer": true,
  // 禁用 gopls 更新检查
  "go.checkForUpdates": "disable",

  // Python 语言支持（需要安装 coc-python）
  // "python.linting.enabled": true,
  // "python.linting.pylintEnabled": false,
  // "python.linting.flake8Enabled": true,

  // TypeScript/JavaScript 支持（需要安装 coc-tsserver）
  // "typescript.preferences.importModuleSpecifier": "relative",
  // "javascript.preferences.importModuleSpecifier": "relative",

  // JSON 支持（需要安装 coc-json）
  // "json.schemas": [],
  // "json.enable": true,

  // ============================================================================
  // 其他配置
  // ============================================================================

  // 工作区配置
  "workspace.ignoredFolders": [
    "**/.git",
    "**/node_modules",
    "**/.vim"
  ],

  // 文件监听配置
  "coc.preferences.rootPatterns": [
    ".git",
    ".vim",
    ".hg"
  ],

  // 代码格式化配置
  "coc.preferences.formatOnSave": false,
  "coc.preferences.formatOnType": false,

  // 代码操作配置
  "coc.preferences.codeLens.enable": true,

  // 补全触发字符
  "coc.preferences.triggerCharacters": [
    ".",
    ":",
    "$",
    "#",
    "@"
  ],

  // ============================================================================
  // 扩展更新检查配置
  // ============================================================================

  // 禁用扩展自动更新检查（包括 gopls）
  // 可选值: "never" (从不检查), "daily" (每天检查), "weekly" (每周检查)
  "extensions.updateCheck": "never",

  // 兼容旧版本配置（已弃用，但保留以确保兼容性）
  "coc.preferences.extensionUpdateCheck": "never",

  // ============================================================================
  // 扩展自动更新配置
  // ============================================================================
  
  // extensionAutoUpdate: 控制已安装的扩展是否自动更新
  // - true: 已安装的扩展会自动更新到最新版本（无需手动执行 :CocUpdate）
  // - false: 需要手动执行 :CocUpdate 来更新扩展（默认值）
  // 注意：此选项只影响已安装扩展的更新，不影响扩展的初始安装
  "coc.preferences.extensionAutoUpdate": false,

  // ============================================================================
  // 关于 coc.nvim 原生推荐安装功能
  // ============================================================================
  //
  // coc.nvim 确实有原生功能来自动安装推荐的扩展！
  // 需要在 Vim 配置文件中定义 g:coc_global_extensions 变量
  //
  // 示例（在 ~/.vim/after/plugin/coc.vim 中添加）：
  // let g:coc_global_extensions = [
  //       \ 'coc-go',
  //       \ 'coc-json',
  //       \ 'coc-vimlsp',
  //       \ 'coc-sh',
  //       \ 'coc-yaml'
  //       \ ]
  //
  // 当定义了这个变量后，coc.nvim 会在启动时自动检查并安装这些扩展
  // （如果它们还没有安装的话）
  //
  // 注意：extensionAutoUpdate 和 g:coc_global_extensions 是两个不同的功能：
  // - g:coc_global_extensions: 控制哪些扩展应该被自动安装（首次安装）
  // - extensionAutoUpdate: 控制已安装扩展是否自动更新
}
