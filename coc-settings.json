{
  // 全局保存时自动格式化
  "coc.preferences.formatOnSave": true,
  // 禁止自动选中第一个补全项
  "suggest.noselect": true,
  // Go: 保存时自动整理 import（排序、增删未使用/缺失的包）
  "[go]": {
    "editor.codeActionsOnSave": {
      "source.organizeImports": true
    }
  },
  "go.goplsOptions": {
    "completeUnimported": true
  },
  "snippets.ultisnips.pythonPrompt": false
}
