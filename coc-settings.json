{
  // 全局保存时自动格式化
  "coc.preferences.formatOnSave": true,
  "coc.preferences.formatOnSaveFiletypes": ["proto", "c", "cpp"],

  // C/C++ (clangd) — 安裝擴展後生效: :CocInstall coc-clangd
  // --query-driver 讓 clangd 向系統裡的 gcc/clang 查詢標準庫路徑，解決 Windows 下找不到 stdio.h 的假報錯
  "clangd.arguments": [
    "--background-index",
    "--clang-tidy",
    "--header-insertion=iwyu",
    "--completion-style=detailed",
    "--query-driver=*"
  ],
  "[c]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.formatOnSave": true
  },
  "[cpp]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.formatOnSave": true
  },

  "languageserver": {
    "protobuf": {
      "command": "buf",
      "args": ["beta", "lsp"],
      "filetypes": ["proto"],
      "rootPatterns": ["buf.yaml", ".git"]
    }
  },

  // 禁止自动选中第一个补全项
  "suggest.noselect": true,
  // 输入变化后等待 100ms 再请求补全，减少频繁请求
  "suggest.triggerCompletionWait": 200,
  // 诊断信息显示前等待 300ms，避免光标快速移动时刷屏
  "diagnostic.messageDelay": 300,
  // 用 echo 代替 float，避免在诊断行间移动时光标处浮动窗反复开关导致闪烁
  //"diagnostic.messageTarget": "echo",
  // 禁止 gopls 进行更新检查
  "go.checkForUpdates": "off",
  // Go: 保存时自动整理 import
  "[go]": {
    "editor.codeActionsOnSave": {
      "source.organizeImports": true
    }
  },

  // 禁用 ultisnips 的 Python 提示
  "snippets.ultisnips.pythonPrompt": false
}