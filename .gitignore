" =======================================================
" [.gitignore] Vim 配置目录 Git 忽略规则
" =======================================================

" --- 1. 插件目录 ---
" vim-plug 管理的插件目录，不需要版本控制
plugged/

" --- 2. Vim 临时文件 ---
" 交换文件（编辑时自动生成）
*.swp
*.swo
*.swn
*~

" --- 3. 备份文件 ---
" 自动备份文件
*.bak
*.backup
*.tmp

" --- 4. 撤销文件 ---
" Vim 撤销历史文件
*.un~

" --- 5. 会话文件 ---
" Vim 会话保存文件
*.viminfo
Session.vim
Sessionx.vim

" --- 6. 标签文件 ---
" 代码索引标签文件
tags
TAGS

" --- 7. 日志文件 ---
" 插件或脚本生成的日志
*.log

" --- 8. 系统文件 ---
" macOS
.DS_Store
.AppleDouble
.LSOverride

" Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

" Linux
*~
.directory
.Trash-*

" --- 9. 其他临时文件 ---
" 临时目录
tmp/
temp/
*.tmp

" --- 10. 个人配置文件（可选）---
" 如果不想提交某些个人配置，可以取消注释
" coc-settings.json
" tasks.ini
