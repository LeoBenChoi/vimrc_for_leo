# ============================================================================
# Vim 配置目录 .gitignore
# ============================================================================

# ============================================================================
# 自动生成的目录（Vim 运行时创建）
# ============================================================================
# 备份文件目录
.backup/
# 交换文件目录
.swap/
# 撤销历史目录
.undo/
# 视图文件目录
.view/
# viminfo 文件（保存标记、寄存器、历史记录等）
.viminfo
*.viminfo

# ============================================================================
# 插件目录（vim-plug 安装的第三方插件）
# ============================================================================
# 注意：autoload/plug.vim 应该保留（vim-plug 插件管理器本身）
plugged/

# ============================================================================
# 会话和临时文件
# ============================================================================
# vim-startify 会话文件
sessions/
*.session
*.session.lock

# ============================================================================
# FZF 历史文件
# ============================================================================
fzf-history/

# ============================================================================
# Coc.nvim 自动生成的文件
# ============================================================================
# coc-settings.json 应该保留（用户配置）
# 但忽略其他自动生成的文件
.coc/

# ============================================================================
# 临时文件和系统文件
# ============================================================================
# Vim 临时文件
*.swp
*.swo
*~
*.tmp
*.bak
*.orig

# 系统文件
.DS_Store
Thumbs.db
desktop.ini

# ============================================================================
# 日志和调试文件
# ============================================================================
*.log
*.debug

# ============================================================================
# 其他
# ============================================================================
# 本地配置文件（如果有）
local/
local.vim
local.vimrc
