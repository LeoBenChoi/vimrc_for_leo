# ============================================================================
# Vim 配置目录 .gitignore
# ============================================================================

# ============================================================================
# 自动生成的目录（Vim 运行时创建）
# ============================================================================
# 备份文件目录
.backup/
backup/
# 交换文件目录
.swap/
swap/
# 撤销历史目录（persistent undo）
.undo/
undodir/
# 视图文件目录（保存折叠状态、光标位置等）
.view/
view/
# viminfo 文件（保存标记、寄存器、历史记录等）
.viminfo
*.viminfo

# ============================================================================
# 插件目录（vim-plug 安装的第三方插件）
# ============================================================================
# 注意：autoload/plug.vim 应该保留（vim-plug 插件管理器本身）
plugged/

# ============================================================================
# 会话和临时文件
# ============================================================================
# vim-startify 会话文件
sessions/
*.session
*.session.lock

# ============================================================================
# FZF 相关文件
# ============================================================================
# FZF 历史文件
fzf-history/
# FZF 二进制文件（会自动安装）
fzf/
# FZF 临时文件
.fzf/

# ============================================================================
# Coc.nvim 自动生成的文件
# ============================================================================
# coc-settings.json 应该保留（用户配置）
# 但忽略其他自动生成的文件和目录
.coc/
coc-*
# Coc.nvim 扩展数据目录
coc/extensions/
# Coc.nvim 日志文件
coc.log

# ============================================================================
# 临时文件和系统文件
# ============================================================================
# Vim 临时文件
*.swp
*.swo
*.tmp
*.bak
*.orig
*~
.*.sw?
.*.un~

# 系统文件
.DS_Store
Thumbs.db
desktop.ini

# ============================================================================
# 日志和调试文件
# ============================================================================
*.log
*.debug

# ============================================================================
# 插件特定文件
# ============================================================================
# vim-go 生成的标签文件
tags
TAGS
# vim-gitgutter 缓存
.gitgutter/
# NERDTree 书签文件（如果不想提交个人书签）
NERDTreeBookmarks
# Vista 缓存
.vista_cache/
# Startify 书签（如果不想提交个人书签）
.vim_startify_bookmarks

# ============================================================================
# WakaTime 隐私与数据文件
# ============================================================================
# WakaTime 主目录（包含所有配置和数据文件）
# 注意：wakatime/ 目录包含敏感信息（API Key）和自动生成的文件
# 忽略整个目录，但保留配置文件模板作为文档
wakatime/

# 保留配置文件模板（需要提交到 Git）
!wakatime/.wakatime.cfg.example
```

# ============================================================================
# 其他
# ============================================================================
# 本地配置文件（如果有）
local/
local.vim
local.vimrc
# 测试和临时目录
test/
tmp/
temp/
