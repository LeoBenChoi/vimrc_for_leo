" ============================================================================
" 映射配置 - P (Plugin)
" ============================================================================

" 插件管理（vim-plug）
nnoremap <leader>pi :PlugInstall<CR>    " 安装插件
nnoremap <leader>pu :PlugUpdate<CR>     " 更新插件
nnoremap <leader>pc :PlugClean<CR>      " 清理未使用的插件
nnoremap <leader>ps :PlugStatus<CR>      " 查看插件状态
