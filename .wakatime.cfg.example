# ============================================================================
# WakaTime 配置文件模板
# ============================================================================
# 文件位置: ~/.vim/.wakatime.cfg
# 说明: 复制此文件为 .wakatime.cfg 并填入你的 API Key
# 获取 API Key: https://wakatime.com/settings/api-key
# ============================================================================

[settings]
# ============================================================================
# 必需配置
# ============================================================================

# API Key（必需）
# 从 https://wakatime.com/settings/api-key 获取
# 注意：此文件已加入 .gitignore，不会提交到 Git 仓库
api_key = your_api_key_here

# API 服务器地址（可选，默认值如下）
# 一般不需要修改，除非使用自托管服务器
api_url = https://api.wakatime.com/api/v1

# ============================================================================
# 隐私保护 - 混淆选项（推荐配置）
# ============================================================================

# 混淆文件名
# 设置为 true 后，所有文件名会被替换为 HIDDEN.ext 格式
# 例如：main.py -> HIDDEN.py, config.json -> HIDDEN.json
# 效果：在仪表盘中，相同扩展名的文件会被合并统计
# 用途：隐藏具体的文件名称，保护项目结构信息
hide_file_names = false

# 混淆项目名称
# 设置为 true 后，项目名称会被替换为随机字符串
# 会在每个项目目录下生成 .wakatime-project 文件存储随机名称
# 效果：在仪表盘中，项目名称显示为随机字符串
# 用途：隐藏项目名称，保护项目信息
hide_project_names = false

# 隐藏项目文件夹路径
# 设置为 true 后，只发送相对路径（相对于项目根目录）
# 例如：/Users/username/projects/flask/src/main.py -> src/main.py
# 如果没有检测到 Git 项目，则只发送文件名
# 效果：在仪表盘中，文件路径不包含完整的绝对路径
# 用途：隐藏用户目录结构、用户名等信息
hide_project_folder = false

# ============================================================================
# 功能开关
# ============================================================================

# 禁用 WakaTime（临时关闭跟踪）
# 设置为 true 可以临时禁用 WakaTime，而不需要卸载插件
disabled = false

# 调试模式
# 设置为 true 会输出详细的调试日志到 .wakatime.log
# 用于排查问题，正常使用建议保持 false
debug = false

# 状态栏显示
# 控制是否在编辑器状态栏显示 WakaTime 信息
status_bar_enabled = true

# 状态栏显示今日编码活动
# 在状态栏显示今天的编码时长统计
status_bar_coding_activity = true

# ============================================================================
# 高级配置
# ============================================================================

# 代理服务器（如果需要通过代理访问）
# 格式：https://user:pass@host:port 或 http://host:port
# 示例：proxy = https://proxy.example.com:8080
# proxy = 

# 禁用 SSL 证书验证（不推荐）
# 仅在开发环境或自签名证书时使用
# 警告：会降低安全性，生产环境不要启用
no_ssl_verify = false

# 从安全存储获取 API Key（高级用法）
# 使用系统密钥库存储 API Key，而不是明文写在配置文件中
# macOS 示例：api_key_vault_cmd = security find-generic-password -s wakatime -w
# Windows 示例：api_key_vault_cmd = powershell -Command "(Get-Content $env:USERPROFILE\.wakatime_key).Trim()"
# Linux 示例：api_key_vault_cmd = secret-tool lookup service wakatime key api_key
# 注意：如果设置了此选项，上面的 api_key 配置会被忽略
# api_key_vault_cmd = 

# ============================================================================
# 混淆配置建议
# ============================================================================
#
# 根据隐私需求，可以选择以下配置组合：
#
# 1. 最小隐私保护（推荐）：
#    hide_project_folder = true
#    效果：隐藏绝对路径，但保留项目结构和文件名
#
# 2. 中等隐私保护：
#    hide_project_folder = true
#    hide_project_names = true
#    效果：隐藏路径和项目名，但保留文件名
#
# 3. 最大隐私保护：
#    hide_file_names = true
#    hide_project_names = true
#    hide_project_folder = true
#    效果：只显示语言类型和编码时长，完全隐藏项目信息
#
# 注意：
# - 修改混淆设置后，历史数据不会自动更新
# - 如需清除历史数据，请访问：https://wakatime.com/delete
# - 混淆设置会影响仪表盘的统计展示，请根据实际需求选择
#
# ============================================================================
